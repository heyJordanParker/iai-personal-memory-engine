recursive-include rust *.rs *.toml *.lock
recursive-include rust/iai_mcp_native/src *
recursive-include rust/iai_mcp_embed_core/src *
recursive-include rust/iai_mcp_graph_core/src *

# Type stubs for the native extension — staged beside the compiled .so at wheel time
include rust/iai_mcp_native/iai_mcp_native/*.pyi
include rust/iai_mcp_native/iai_mcp_native/py.typed

# Deploy files: launchd plist, systemd unit, hook scripts
recursive-include src/iai_mcp/_deploy *

# TS wrapper source — so an sdist-to-wheel rebuild can compile the wrapper
recursive-include mcp-wrapper/src *
include mcp-wrapper/package.json
include mcp-wrapper/package-lock.json
include mcp-wrapper/tsconfig.json
prune mcp-wrapper/node_modules
prune mcp-wrapper/dist
